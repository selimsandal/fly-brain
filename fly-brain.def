Bootstrap: docker
From: nvidia/cuda:13.1.1-cudnn-devel-ubuntu24.04

%labels
    Author fly-brain
    Description Drosophila fly brain LIF model (Brian2, Brian2CUDA, PyTorch, NEST GPU)

%environment
    export PATH="/opt/miniconda3/envs/brain-fly/bin:/opt/miniconda3/bin:${PATH}"
    export CONDA_DEFAULT_ENV=brain-fly
    export LD_LIBRARY_PATH="/usr/local/cuda/lib64:${LD_LIBRARY_PATH}"
    export PYTHONUNBUFFERED=1
    export NESTGPU_INSTALL=/opt/nest-gpu-install
    export PYTHONPATH="${NESTGPU_INSTALL}/lib/python3.10/site-packages:${PYTHONPATH}"

%files
    environment.yml /opt/fly-brain/environment.yml
    main.py /opt/fly-brain/main.py
    code /opt/fly-brain/code
    data /opt/fly-brain/data

%post
    # ---- Verify file layout ----
    ls /opt/fly-brain/code/benchmark.py

    # ---- System packages ----
    apt-get update && apt-get install -y --no-install-recommends \
        build-essential \
        cmake \
        git \
        wget \
        ca-certificates \
        libgomp1 \
        libomp-dev \
        libopenmpi-dev \
        openmpi-bin \
        python3-dev \
        python3-mpi4py \
        pkg-config \
        libgsl-dev \
        libltdl-dev \
        libreadline-dev \
        libncurses-dev \
        autoconf \
        automake \
        libtool \
        && rm -rf /var/lib/apt/lists/*

    # ---- Install Miniconda ----
    wget -q https://repo.anaconda.com/miniconda/Miniconda3-latest-Linux-x86_64.sh \
        -O /tmp/miniconda.sh
    bash /tmp/miniconda.sh -b -p /opt/miniconda3
    rm /tmp/miniconda.sh
    export PATH="/opt/miniconda3/bin:${PATH}"

    # ---- Accept Anaconda ToS non-interactively ----
    # https://github.com/anaconda/conda-anaconda-tos
    export CONDA_PLUGINS_AUTO_ACCEPT_TOS=true

    # ---- Create conda environment from environment.yml ----
    conda env create -f /opt/fly-brain/environment.yml
    conda clean -afy

    # ---- Activate environment for remaining build steps ----
    export PATH="/opt/miniconda3/envs/brain-fly/bin:${PATH}"
    export CONDA_DEFAULT_ENV=brain-fly

    # ---- Build NEST GPU from source (optional: --nestgpu backend) ----
    cd /tmp
    rm -rf nest-gpu nest-gpu-build
    git clone https://github.com/nest/nest-gpu.git
    mkdir nest-gpu-build && cd nest-gpu-build

    cmake \
        -DCMAKE_INSTALL_PREFIX=/opt/nest-gpu-install \
        -DCMAKE_CUDA_ARCHITECTURES=native \
        /tmp/nest-gpu

    make -j"$(nproc)"
    make install
    cd / && rm -rf /tmp/nest-gpu /tmp/nest-gpu-build

    # ---- Create results directory ----
    mkdir -p /opt/fly-brain/data/results

%runscript
    cd /opt/fly-brain
    exec /opt/miniconda3/envs/brain-fly/bin/python main.py "$@"

%help
    Drosophila fly brain LIF benchmark container.

    Usage (all backends, default settings):
        apptainer run --nv fly-brain.sif

    Specific backends:
        apptainer run --nv fly-brain.sif --brian2-cpu
        apptainer run --nv fly-brain.sif --brian2cuda-gpu
        apptainer run --nv fly-brain.sif --pytorch
        apptainer run --nv fly-brain.sif --nestgpu

    Custom duration and trials:
        apptainer run --nv fly-brain.sif --pytorch --t_run 0.1 1 --n_run 1

    Interactive shell:
        apptainer shell --nv fly-brain.sif

    NOTE: Always pass --nv to enable GPU access inside the container.
    NOTE: NEST GPU is built with CMAKE_CUDA_ARCHITECTURES=native,
          which auto-detects the GPU present at build time.
